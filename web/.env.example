# Optional: a Hugging Face Inference Endpoint serving the trained model.
# When set, the API routes (/api/move, /api/predict) proxy to it via
# web/app/lib/hf.ts; otherwise the built-in TypeScript fallback agent
# (chess.js heuristic) is used so the site always works.
#
# HF_ENDPOINT_URL  - the Inference Endpoint URL (this is what drives inference)
# HF_API_TOKEN     - a read token; only needed if the endpoint is Protected
# HF_MODEL_ID      - display/model-card link only (not used for inference)
HF_ENDPOINT_URL=
HF_API_TOKEN=
HF_MODEL_ID=legacyaravind/shannons-gambit
