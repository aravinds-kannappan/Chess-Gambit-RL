# The web app talks to the Hugging Face Space that trains + serves the agents.
# Every move/prediction comes from a trained network - there is no fallback, so
# the Space must be reachable for play/watch/predict to work.
#
# HF_SPACE_URL    - your deployed Space URL, e.g. https://<user>-<space>.hf.space
# HF_SPACE_TOKEN  - optional bearer token if the Space is private
HF_SPACE_URL=
HF_SPACE_TOKEN=
